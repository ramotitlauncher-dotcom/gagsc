local function grab(part, typ)
	local character = LocalPlayer.Character
	if not character or not character.PrimaryPart then return end
	local hum = character:FindFirstChildOfClass("Humanoid")
	if not hum or hum.Health <= 0 then return end

	local beforeCount = countBackpack()
	local success = false

	-- teleport ke seed
	character:PivotTo(CFrame.new(part.Position + Vector3.new(0, 3, 0)))
	task.wait()

	if part.Parent then
		-- cara 1: fireproximityprompt (cara yang terbukti berhasil)
		local prompt = part:FindFirstChildOfClass("ProximityPrompt")
			or part:FindFirstChild("BuyPrompt")
		if prompt then
			pcall(function() fireproximityprompt(prompt) end)
			pcall(function() fireproximityprompt(prompt) end)
			pcall(function() fireproximityprompt(prompt) end)
		end

		-- cara 2: ClickPack fallback
		pcall(function() networking.SeedPack.ClickPack:Fire(part.Name) end)
		pcall(function() networking.SeedPack.ClickPack:Fire(part) end)
	end

	-- tunggu sebentar lalu cek inventory beneran bertambah
	task.wait(0.3)
	local afterCount = countBackpack()
	success = afterCount > beforeCount

	if typ then
		if success then
			statusData[typ].lastCollected = formatTime()
			statusData[typ].total += 1
			statusData[typ].waiting = false
			allSeedStatus.totalClaimed += 1
			table.insert(grabLog, string.format("[%s] CLAIMED %s seed", formatTime(), typ))
			if typ == "rainbow" then
				than("🌈 Rainbow Seed berhasil diklaim!", 4, Color3.fromRGB(255, 100, 255), "HexRoot Hub", "Seed Collector")
			elseif typ == "gold" then
				than("⭐ Gold Seed berhasil diklaim!", 4, Color3.fromRGB(255, 215, 0), "HexRoot Hub", "Seed Collector")
			end
		else
			statusData[typ].miss += 1
			allSeedStatus.totalMiss += 1
			table.insert(grabLog, string.format("[%s] MISS %s seed", formatTime(), typ))
			if typ == "rainbow" then
				than("❌ Gagal klaim Rainbow Seed", 3, Color3.fromRGB(255, 80, 80), "HexRoot Hub", "Seed Collector")
			elseif typ == "gold" then
				than("❌ Gagal klaim Gold Seed", 3, Color3.fromRGB(255, 80, 80), "HexRoot Hub", "Seed Collector")
			end
		end
		if #grabLog > 50 then table.remove(grabLog, 1) end
		updateStatusLabel(typ)
		updateAllSeedLabel()
	end
end

local function waitForSeedAttr(part, timeout)
	timeout = timeout or 2
	local deadline = os.clock() + timeout
	while os.clock() < deadline and part.Parent do
		local isRainbow = part:GetAttribute("RainbowSeed") == true
		local isGold    = part:GetAttribute("GoldSeed")    == true
		local packName  = part:GetAttribute("SeedPack")
		if isRainbow or isGold or packName ~= nil then
			return isRainbow, isGold
		end
		task.wait(0.05)
	end
	return false, false
end


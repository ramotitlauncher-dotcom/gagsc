local CyclePhases = {}
for name, data in TimeCycleData.Data, nil, nil do
	table.insert(CyclePhases, {
		Name = name,
		Weathers = data.Weathers,
		Duration = data.Lasts,
		Order = data.StartOrder
	})
end
table.sort(CyclePhases, function(a, b) return a.Order < b.Order end)

local TotalCycleDuration = 0
for _, phase in CyclePhases, nil, nil do
	TotalCycleDuration += phase.Duration
end

local PhaseIndexByName = {}
for i, phase in CyclePhases, nil, nil do
	PhaseIndexByName[phase.Name] = i
end

local ClockOffset = workspace:GetServerTimeNow() - DateTime.now().UnixTimestamp

local function serverSyncedNow()
	return DateTime.now().UnixTimestamp + ClockOffset
end

local function pickWeather(phase, rng)
	local totalChance = 0
	for _, w in phase.Weathers, nil, nil do
		totalChance += w.Chance
	end
	local roll = rng:NextNumber()
	local acc = 0
	for name, w in phase.Weathers, nil, nil do
		acc += w.Chance
		if roll * totalChance <= acc then
			return name, w
		end
	end
	for name, w in phase.Weathers, nil, nil do
		return name, w
	end
end

local function getWeatherForPhase(cycleIndex, phaseIndex, phase)
	local rng = Random.new(cycleIndex * 1000 + phaseIndex)
	return pickWeather(phase, rng)
end

local function waitForCycleAttributes()
	local activePhase = workspace:GetAttribute("ActivePhase")
	local phaseDuration = workspace:GetAttribute("PhaseDuration")
	while not activePhase or not phaseDuration do
		task.wait(0.1)
		activePhase = workspace:GetAttribute("ActivePhase")
		phaseDuration = workspace:GetAttribute("PhaseDuration")
	end
	return activePhase, phaseDuration
end

local function getCycleState()
	local activePhaseName, phaseDuration = waitForCycleAttributes()
	local serverNow = workspace:GetServerTimeNow()
	local remaining = math.max(0, phaseDuration - serverNow)
	local phaseIndex = PhaseIndexByName[activePhaseName]
	if not phaseIndex then phaseIndex = 1 end
	local phase = CyclePhases[phaseIndex]
	local elapsed = phase.Duration - remaining
	local now = os.time()
	local approxCycleIndex = math.floor(now / TotalCycleDuration)
	return approxCycleIndex, phaseIndex, phase, elapsed, remaining
end

local function predictUpcoming(count)
	local results = {}
	local cycleIndex, phaseIndex, phase, elapsed, remaining = getCycleState()
	local curCycle, curPhaseIdx = cycleIndex, phaseIndex
	local timeUntil = remaining
	for i = 1, count do
		curPhaseIdx += 1
		if curPhaseIdx > #CyclePhases then
			curPhaseIdx = 1
			curCycle += 1
		end
		local nextPhase = CyclePhases[curPhaseIdx]
		local weatherName, weatherData = getWeatherForPhase(curCycle, curPhaseIdx, nextPhase)
		table.insert(results, {
			PhaseName = nextPhase.Name,
			WeatherName = weatherName,
			WeatherData = weatherData,
			Duration = nextPhase.Duration,
			TimeUntil = timeUntil,
		})
		timeUntil += nextPhase.Duration
	end
	return results
end

local function formatTimeCycle(seconds)
	seconds = math.max(0, math.floor(seconds))
	local m = math.floor(seconds / 60)
	local s = seconds % 60
	if m > 0 then return string.format("%dm %ds", m, s) end
	return string.format("%ds", s)
end

local function findNextOccurrences(targetPhaseName, targetWeatherNames, maxResults, maxCyclesToScan)
	maxResults = maxResults or 3
	maxCyclesToScan = maxCyclesToScan or 1000
	local targetPhaseIndex = PhaseIndexByName[targetPhaseName]
	local targetPhase = CyclePhases[targetPhaseIndex]
	if not targetPhase then return {} end
	local wanted = {}
	for _, n in targetWeatherNames, nil, nil do
		wanted[n] = true
	end
	local cycleIndex, phaseIndex, _, _, remaining = getCycleState()
	local results = {}
	local timeUntil = remaining
	local scanCycle, scanPhase = cycleIndex, phaseIndex
	for c = 0, maxCyclesToScan do
		while scanPhase ~= targetPhaseIndex do
			scanPhase += 1
			if scanPhase > #CyclePhases then
				scanPhase = 1
				scanCycle += 1
			end
			timeUntil += CyclePhases[scanPhase].Duration
		end
		local weatherName = getWeatherForPhase(scanCycle, scanPhase, targetPhase)
		if wanted[weatherName] then
			table.insert(results, {
				WeatherName = weatherName,
				TimeUntil = timeUntil - targetPhase.Duration,
			})
			if #results >= maxResults then break end
		end
		scanPhase += 1
		if scanPhase > #CyclePhases then
			scanPhase = 1
			scanCycle += 1
		end
		timeUntil += CyclePhases[scanPhase].Duration
	end
	return results
end

local function getWeatherMachineState(weatherName)
	local playing = WeatherValues:GetAttribute(weatherName .. "_Playing")
	local endTime = WeatherValues:GetAttribute(weatherName .. "_EndTime")
	local now = serverSyncedNow()
	local remaining = math.max(0, (endTime or 0) - now)
	return playing, remaining
end

local function formatTime()
	local t = os.date("*t")
	return string.format("%02d:%02d:%02d", t.hour, t.min, t.sec)
end


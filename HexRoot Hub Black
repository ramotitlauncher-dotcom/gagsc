task.spawn(function()
	local lastMoonScan = 0
	while true do
		local ok, err = pcall(function()
			local cycleIndex, phaseIndex, phase, elapsed, remaining = getCycleState()
			local weatherName, weatherData = getWeatherForPhase(cycleIndex, phaseIndex, phase)

			CurrentPhaseLabel:SetContent(phase.Name)
			CurrentWeatherLabel:SetContent(weatherName)
			TimeRemainingLabel:SetContent(formatTimeCycle(remaining))

			local upcoming = predictUpcoming(#UpcomingLabels)
			for i, data in ipairs(upcoming) do
				UpcomingLabels[i]:SetContent(string.format("%s (%s) — in %s", data.PhaseName, data.WeatherName, formatTimeCycle(data.TimeUntil)))
			end

			for _, w in WeatherData.Data, nil, nil do
				local playing, timeLeft = getWeatherMachineState(w.Name)
				local content
				if playing then
					content = "ACTIVE — ends in " .. formatTimeCycle(timeLeft)
				else
					content = "Inactive"
				end
				if WeatherEventLabels[w.Name] then
					WeatherEventLabels[w.Name]:SetContent(content)
				end
			end

			do
				local rawEndTime = WeatherValues:GetAttribute("Rain_EndTime") or 0
				local rawPlaying = WeatherValues:GetAttribute("Rain_Playing")
				local clientNow = DateTime.now().UnixTimestamp
				local syncedNow = serverSyncedNow()
				local rawRemaining = rawEndTime - clientNow
				local correctedRemaining = rawEndTime - syncedNow
				RainDebugLabel:SetContent(string.format(
					"Playing=%s | EndTime=%d | ClientNow=%d | SyncedNow=%d | RawLeft=%ds | CorrectedLeft=%ds",
					tostring(rawPlaying), rawEndTime, clientNow, syncedNow, rawRemaining, correctedRemaining
				))
			end

			if os.clock() - lastMoonScan >= 5 then
				lastMoonScan = os.clock()
				local goldmoons = findNextOccurrences("Night", { "Goldmoon" }, 3, 1000)
				local rainbowMoons = findNextOccurrences("Night", { "Rainbow Moon" }, 3, 2000)
				if #goldmoons > 0 then
					GoldmoonLabel:SetContent("in " .. formatTimeCycle(goldmoons[1].TimeUntil))
					local lines = {}
					for _, g in ipairs(goldmoons) do table.insert(lines, formatTimeCycle(g.TimeUntil)) end
					NextGoldmoonsLabel:SetContent(table.concat(lines, " | "))
				else
					GoldmoonLabel:SetContent("Not found in scan range")
					NextGoldmoonsLabel:SetContent("-")
				end
				if #rainbowMoons > 0 then
					RainbowMoonLabel:SetContent("in " .. formatTimeCycle(rainbowMoons[1].TimeUntil))
					local lines = {}
					for _, r in ipairs(rainbowMoons) do table.insert(lines, formatTimeCycle(r.TimeUntil)) end
					NextRainbowMoonsLabel:SetContent(table.concat(lines, " | "))
				else
					RainbowMoonLabel:SetContent("Not found in scan range")
					NextRainbowMoonsLabel:SetContent("-")
				end
			end
		end)
		if not ok then warn("[Weather Predictor] Update error:", err) end
		task.wait(1)
	end
end)

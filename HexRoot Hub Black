local function getAllSeedTools()
	local tools = {}
	local function scanContainer(c)
		if not c then return end
		for _, item in ipairs(c:GetChildren()) do
			if item:IsA("Tool") and item:GetAttribute("SeedTool") then
				table.insert(tools, item)
			end
		end
	end
	scanContainer(LocalPlayer.Character)
	scanContainer(LocalPlayer:FindFirstChild("Backpack"))
	return tools
end

local function getEquippedSeedTool(seedName)
	local function findIn(c)
		if not c then return nil end
		for _, item in ipairs(c:GetChildren()) do
			if item:IsA("Tool") and item:GetAttribute("SeedTool") == seedName then
				return item
			end
		end
	end
	return findIn(LocalPlayer.Character) or findIn(LocalPlayer:FindFirstChild("Backpack"))
end




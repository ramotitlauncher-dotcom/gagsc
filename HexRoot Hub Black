			end
			if not tool then continue end
			for _, area in ipairs(plantAreas) do
				if isSlotEmpty(area, plantsFolder) then
					local pos = randomPosInArea(area)
					networking.Plant.PlantSeed:Fire(pos, selectedPlantSeed, tool)
					task.wait(0.08)
